# List supported MCP server names for mcpadd/mcpremove

echo "Available MCP servers:"
cat <<'NAMES'
Context7
sequential-thinking
foundry-mcp-server
code-index
rust-docs            [auto-clones github.com/Govcraft/rust-docs-mcp-server if needed]
basic-memory
fetch
pdf-reader
xcode                [auto-clones github.com/r-huijts/xcode-mcp-server if needed]
perplexity-ask       [requires PERPLEXITY_API_KEY]
calculator
playwright
n8n                  [requires N8N_API_KEY; optional N8N_API_URL]
brave-search         [requires BRAVE_API_KEY]
mindmap
puppeteer            [optional PUPPETEER_ARGS env var]
task-master-ai       [optional MODEL, PERPLEXITY_MODEL, MAX_TOKENS, TEMPERATURE, DEFAULT_SUBTASKS, DEFAULT_PRIORITY]
tree-sitter-mcp
iterm-mcp
crypto-market-data
NAMES

echo
echo "Project/local scope only (never user/global):"
cat <<'RESTRICTED'
repowise         [project scope only — installs via uv, runs repowise init (~25 min, ~$50)]
cerebra-legal    [project/local scope only — auto-clones github.com/yoda-digital/mcp-cerebra-legal-server]
us-legal         [project/local scope only — requires CONGRESS_API_KEY, COURT_LISTENER_API_KEY]
